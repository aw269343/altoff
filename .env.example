# Файл с переменными окружения для Production среды
# Переименуйте этот файл в .env на сервере

# Случайная строка для JWT токенов (Сгенерируйте через: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-here

# Данные для первого администратора
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password!

# Разрешенные домены для CORS (через запятую, без пробелов, для Production обязательно указать домен)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your-domain.com

# Строка подключения к базе данных (по умолчанию используется локальная SQLite /fulfillment.db)
# DATABASE_URL=postgresql://user:password@localhost/dbname
